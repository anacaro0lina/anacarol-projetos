import requests
import webbrowser
import os # Importado para lidar com caminhos de arquivo

def consultar_cep(cep):
    url = f"https://viacep.com.br/ws/{cep}/json/"
    
    try:
        # Adicionei um timeout para evitar que o código trave se o site cair
        resposta = requests.get(url, timeout=10)
        resposta.raise_for_status() # Levanta erro se o status não for 200
        
        dados = resposta.json()

        if "erro" not in dados:
            html_content = f"""
            <html>
            <head>
                <meta charset="utf-8">
                <title>Consulta de CEP</title>
                <style>
                    body {{ font-family: sans-serif; padding: 20px; line-height: 1.6; }}
                    h1 {{ color: #2c3e50; }}
                    b {{ color: #2980b9; }}
                </style>
            </head>
            <body>
                <h1>Resultado do CEP</h1>
                <p><b>CEP:</b> {dados.get('cep', '')}</p>
                <p><b>Rua:</b> {dados.get('logradouro', '')}</p>
                <p><b>Bairro:</b> {dados.get('bairro', '')}</p>
                <p><b>Cidade:</b> {dados.get('localidade', '')}</p>
                <p><b>Estado:</b> {dados.get('uf', '')}</p>
            </body>
            </html>
            """

            # Obtém o caminho absoluto do arquivo para o navegador não se perder
            caminho_arquivo = os.path.abspath("resultado.html")
            
            with open(caminho_arquivo, "w", encoding="utf-8") as arquivo:
                arquivo.write(html_content)
            
            # O prefixo 'file://' ajuda o navegador a entender que é um arquivo local
            webbrowser.open(f"file://{caminho_arquivo}")
            
        else:
            print("CEP não encontrado no banco de dados!")
            
    except requests.exceptions.RequestException as e:
        print(f"Erro na requisição: {e}")

def main():
    # Limpa o input de qualquer caractere não numérico
    entrada = input("Digite o CEP: ").strip()
    cep = "".join(filter(str.isdigit, entrada))
    
    if len(cep) != 8:
        print("CEP inválido. Por favor, digite um CEP válido com 8 dígitos.")
    else:
        consultar_cep(cep)

if __name__ == "__main__":
    main()
